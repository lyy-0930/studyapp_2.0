<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 读取外部存储权限（用于选择视频文件） -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- 下载文件到外部存储（API 28及以下需要） -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- 网络权限（用于视频上传） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Android 13+ 媒体权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Android 13+ 图片权限（头像选择） -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- 声明应用需要硬件加速以获得更好的视频播放性能 -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StudyApp"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.StudyApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RegisterActivity"
            android:exported="true"
            android:label="注册"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".StudentActivity"
            android:exported="true"
            android:label="学生界面"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".TeacherActivity"
            android:exported="true"
            android:label="教师界面"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".AdminActivity"
            android:exported="true"
            android:label="管理员界面"
            android:hardwareAccelerated="true"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".UploadActivity"
            android:exported="true"
            android:label="上传"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".ProfileActivity"
            android:exported="true"
            android:label="我的"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".VideoUploadActivity"
            android:exported="true"
            android:label="视频上传"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".CourseListActivity"
            android:exported="true"
            android:label="课程列表"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".MyCoursesActivity"
            android:exported="true"
            android:label="我的课程"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".TeacherStatisticsActivity"
            android:exported="true"
            android:label="数据统计"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".ClassroomActivity"
            android:exported="true"
            android:label="教室统计"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".OnlineUsersActivity"
            android:exported="true"
            android:label="实时在线人数"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".ActivityRankingActivity"
            android:exported="true"
            android:label="活跃率排行榜"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".LearningStatsActivity"
            android:exported="true"
            android:label="学习情况统计"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".CourseMasteryActivity"
            android:exported="true"
            android:label="课程掌握度"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".NetworkTestActivity"
            android:exported="true"
            android:label="网络诊断"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".VideoPlayerActivity"
            android:exported="true"
            android:label="视频播放"
            android:theme="@style/Theme.StudyApp"
            android:configChanges="orientation|screenSize|keyboardHidden" />
        <activity
            android:name=".ExoVideoPlayerActivity"
            android:exported="true"
            android:label="视频播放"
            android:theme="@style/Theme.StudyApp"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:hardwareAccelerated="true" />
        <activity
            android:name=".UserManagementActivity"
            android:exported="true"
            android:label="用户管理"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".DataResetActivity"
            android:exported="true"
            android:label="数据重置"
            android:theme="@style/Theme.StudyApp" />
        <activity
            android:name=".SciFiMonitorActivity"
            android:exported="true"
            android:label="监控中心"
            android:theme="@style/Theme.StudyApp"
            android:hardwareAccelerated="true" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>