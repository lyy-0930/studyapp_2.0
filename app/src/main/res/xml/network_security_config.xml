<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 允许HTTP明文流量（用于开发测试） -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>

        <!-- 允许阿里云OSS域名的HTTP流量 -->
        <domain includeSubdomains="true">oss-cn-beijing.aliyuncs.com</domain>
        <domain includeSubdomains="true">oss-cn-hangzhou.aliyuncs.com</domain>
        <domain includeSubdomains="true">oss-cn-shanghai.aliyuncs.com</domain>
        <domain includeSubdomains="true">oss-cn-shenzhen.aliyuncs.com</domain>
        <domain includeSubdomains="true">oss-cn-guangzhou.aliyuncs.com</domain>
        <domain includeSubdomains="true">oss-cn-chengdu.aliyuncs.com</domain>

        <!-- 通配符匹配所有阿里云OSS域名 -->
        <domain includeSubdomains="true">*.aliyuncs.com</domain>
        <domain includeSubdomains="true">*.aliyun.com</domain>
    </domain-config>

    <!-- 基础配置 -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>