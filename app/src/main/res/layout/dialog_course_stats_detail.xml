<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 课程名称 -->
        <TextView
            android:id="@+id/statsDetailCourseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课程名称"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="16dp" />

        <!-- Tab 切换栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F0F0"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tabStudentsBtn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="👥 学生明细"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:background="@drawable/gradient_tsinghua_purple"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tabAccuracyBtn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="🎯 题目正确率"
                android:textSize="13sp"
                android:textColor="@color/tsinghua_purple_dark"
                android:gravity="center"
                android:background="#E8E8E8"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 学生统计面板 -->
        <LinearLayout
            android:id="@+id/studentsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/studentsLoadingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正在加载学生数据..."
                android:textSize="14sp"
                android:textColor="@color/darker_gray"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/studentsListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- 题目正确率面板 -->
        <LinearLayout
            android:id="@+id/accuracyPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/accuracyLoadingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正在加载题目正确率..."
                android:textSize="14sp"
                android:textColor="@color/darker_gray"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/accuracyListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
