<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <TextView
            android:id="@+id/conversationAvatarText"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/circle_avatar"
            android:backgroundTint="@color/tsinghua_purple"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/conversationAvatarImage"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:visibility="gone" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/conversationName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/tsinghua_purple_dark"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/conversationTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/conversationLastMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#999999"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/conversationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:minWidth="18dp"
                android:paddingHorizontal="5dp"
                android:paddingVertical="1dp"
                android:visibility="gone"
                android:background="@drawable/circle_day"
                android:backgroundTint="@color/tech_red_alert" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
