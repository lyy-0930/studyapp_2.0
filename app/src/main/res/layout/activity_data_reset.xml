<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_tech_blue_layered"
    tools:context=".DataResetActivity">

    <!-- 标题 -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 数据重置工具"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/tech_red_alert"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp" />

    <!-- 描述 -->
    <TextView
        android:id="@+id/descriptionTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="此工具用于清除所有本地存储数据，将应用恢复到刚安装时的状态。\n\n⚠️ 注意：此操作会删除所有用户数据，不可恢复！"
        android:textSize="16sp"
        android:textColor="@color/tech_blue_light"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:lineSpacingExtra="8sp" />

    <!-- 状态显示区域 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/tech_blue_secondary"
        android:layout_marginBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/statusTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正在加载数据状态..."
                android:textSize="14sp"
                android:textColor="@color/tech_blue_light"
                android:lineSpacingExtra="4sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 重置按钮 -->
    <Button
        android:id="@+id/resetButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ 重置所有数据"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/tech_red_alert"
        android:layout_marginBottom="16dp"
        android:paddingVertical="16dp"
        android:elevation="8dp" />

    <!-- 返回按钮 -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="返回"
        android:textSize="16sp"
        android:textColor="@color/tech_blue_light"
        android:backgroundTint="@color/tech_blue_primary"
        android:paddingVertical="12dp"
        android:layout_marginBottom="40dp" />

    <!-- 警告信息 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="使用说明：\n1. 此操作仅清除本地数据，不影响后端服务器数据\n2. 重置后需要重新登录\n3. 课程列表将从服务器重新加载"
        android:textSize="12sp"
        android:textColor="@color/tech_blue_accent"
        android:gravity="center"
        android:alpha="0.8"
        android:lineSpacingExtra="4sp" />

</LinearLayout>