<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/dialogCourseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课程名称"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/dialogCourseTeacher"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="授课教师："
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/dialogCourseCredit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="学分："
                android:textSize="14sp"
                android:textColor="#666666" />

        </LinearLayout>

        <TextView
            android:id="@+id/dialogCourseDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="创建时间："
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/dialogCourseDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="课程描述"
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/dialogPlayVideoBtn"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="▶ 播放视频"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/tsinghua_purple"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/manageQuestionsBtn"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="📝 管理题目"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/tech_cyan_info"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E8E8"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📎 课程资料"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/materialListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/emptyMaterialText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无资料"
            android:textSize="13sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingVertical="24dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/uploadNewMaterialBtn"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="+ 上传新资料"
            android:textSize="14sp"
            android:textColor="@color/tsinghua_purple"
            android:backgroundTint="#F0E6F6"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</ScrollView>
