<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    tools:context=".TeacherActivity">

    <!-- ======================== 左侧导航栏 ======================== -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:elevation="2dp">

        <!-- 用户头像和名称区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:id="@+id/avatarFrame"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/userAvatarText"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:text="师"
                    android:textSize="28sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_avatar"
                    android:backgroundTint="@color/tsinghua_purple"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/userAvatarImage"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

            </FrameLayout>

            <TextView
                android:id="@+id/sidebarUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加载中..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/tsinghua_purple_dark" />

            <TextView
                android:id="@+id/sidebarRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="教师"
                android:textSize="12sp"
                android:textColor="@color/tsinghua_purple"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="2dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E8E8" />

        <!-- 导航菜单 -->
        <LinearLayout
            android:id="@+id/menuContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <!-- 首页 -->
            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/sidebar_item_selector"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🏠"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首页"
                    android:textSize="15sp"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

            <!-- 课程上传 -->
            <LinearLayout
                android:id="@+id/navUploadCourse"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/sidebar_item_selector"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📤"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="课程上传"
                    android:textSize="15sp"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

            <!-- 我的课程 -->
            <LinearLayout
                android:id="@+id/navMyCourses"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/sidebar_item_selector"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📚"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="我的课程"
                    android:textSize="15sp"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

            <!-- 数据统计 -->
            <LinearLayout
                android:id="@+id/navStatistics"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/sidebar_item_selector"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📊"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据统计"
                    android:textSize="15sp"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

            <!-- 消息 -->
            <LinearLayout
                android:id="@+id/navMessage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:background="@drawable/sidebar_item_selector"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="💬"
                    android:textSize="16sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="消息"
                    android:textSize="15sp"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:layout_marginStart="14dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 底部退出 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E8E8" />

        <LinearLayout
            android:id="@+id/navLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="🚪"
                android:textSize="16sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="退出登录"
                android:textSize="15sp"
                android:textColor="#999999"
                android:layout_marginStart="12dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ======================== 右侧主内容 ======================== -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#F5F5F5">

        <!-- 顶部标题图片 -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:src="@drawable/header_bg"
            android:scaleType="centerCrop"
            android:contentDescription="顶部标题" />

        <!-- ==================== 首页内容 ==================== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/homeContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 欢迎卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="32dp">

                        <TextView
                            android:id="@+id/welcomeIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👨‍🏫"
                            android:textSize="64sp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:id="@+id/welcomeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="欢迎回来"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark" />

                        <TextView
                            android:id="@+id/welcomeSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="教师功能面板"
                            android:textSize="16sp"
                            android:textColor="#999999"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 快捷功能卡片 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ 快捷功能"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark"
                            android:layout_marginBottom="16dp" />

                        <!-- 课程上传快捷入口 -->
                        <LinearLayout
                            android:id="@+id/quickUpload"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:background="#F8F8F8"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="📤"
                                android:textSize="20sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="课程上传"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tsinghua_purple_dark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="上传和管理课程视频"
                                    android:textSize="12sp"
                                    android:textColor="#999999" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:text="›"
                                android:textSize="20sp"
                                android:textColor="#999999" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E8E8E8"
                            android:layout_marginVertical="8dp" />

                        <!-- 数据统计快捷入口 -->
                        <LinearLayout
                            android:id="@+id/quickStats"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp"
                            android:background="#F8F8F8"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:text="📊"
                                android:textSize="20sp"
                                android:gravity="center" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="数据统计"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/tsinghua_purple_dark" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="查看学生学习数据"
                                    android:textSize="12sp"
                                    android:textColor="#999999" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:text="›"
                                android:textSize="20sp"
                                android:textColor="#999999" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- 使用提示 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡 使用提示"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text='• 点击左侧"课程上传"可上传教学视频并创建课程'
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text='• 点击左侧"数据统计"可查看课程学习数据'
                            android:textSize="14sp"
                            android:textColor="#666666"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• 上传的视频将自动存储到云端并同步到学生端"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ==================== 课程上传 Fragment 容器 ==================== -->
        <FrameLayout
            android:id="@+id/uploadFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- ==================== 我的课程 ==================== -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/myCoursesContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="40sp"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="我的课程"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark" />

                        <TextView
                            android:id="@+id/myCourseCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="共 0 门课程"
                            android:textSize="14sp"
                            android:textColor="#999999"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/myCoursesRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <LinearLayout
                    android:id="@+id/emptyMyCoursesLayout"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="暂无课程"
                        android:textSize="18sp"
                        android:textColor="#999999" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点击左侧「课程上传」创建你的第一门课程"
                        android:textSize="13sp"
                        android:textColor="#cccccc"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- ==================== 数据统计 Fragment 容器 ==================== -->
        <FrameLayout
            android:id="@+id/statsFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- ==================== 消息 Fragment 容器 ==================== -->
        <FrameLayout
            android:id="@+id/chatFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <!-- ==================== 题目管理 Fragment 容器 ==================== -->
        <FrameLayout
            android:id="@+id/questionManageContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
