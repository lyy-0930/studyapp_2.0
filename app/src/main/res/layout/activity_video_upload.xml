<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp"
    android:background="@drawable/gradient_tsinghua_purple_layered"
    tools:context=".VideoUploadActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 标题区域 -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="40dp">

            <!-- 返回按钮 -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/ic_button_background_selector"
                android:contentDescription="返回"
                tools:ignore="ContentDescription" />

            <!-- 标题 -->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="视频上传"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center" />

            <!-- 占位空间保持对称 -->
            <View
                android:layout_width="48dp"
                android:layout_height="48dp" />

        </LinearLayout>

        <!-- 上传区域卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/uploadCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginHorizontal="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="@color/white"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="48dp"
                android:gravity="center">

                <!-- 视频上传图标 -->
                <TextView
                    android:id="@+id/videoIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎬"
                    android:textSize="64sp"
                    android:layout_marginBottom="32dp" />

                <!-- 课程信息表单 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">

                    <!-- 课程标题 -->
                    <EditText
                        android:id="@+id/courseTitleEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="课程标题"
                        android:inputType="text|textCapSentences"
                        android:maxLines="1"
                        android:background="@drawable/edit_text_background"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp" />

                    <!-- 课程描述 -->
                    <EditText
                        android:id="@+id/courseDescriptionEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="课程描述"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="3"
                        android:maxLines="5"
                        android:background="@drawable/edit_text_background"
                        android:padding="16dp"
                        android:layout_marginBottom="24dp" />

                </LinearLayout>

                <!-- 选择视频按钮 -->
                <Button
                    android:id="@+id/selectVideoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="选择视频文件"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/ic_button_background_selector"
                    android:textColor="@color/white"
                    android:paddingVertical="16dp"
                    android:layout_marginBottom="24dp" />

                <!-- 选中的视频信息 -->
                <LinearLayout
                    android:id="@+id/videoInfoContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:background="@drawable/edit_text_background"
                    android:padding="16dp"
                    android:layout_marginBottom="32dp">

                    <!-- 视频文件名 -->
                    <TextView
                        android:id="@+id/videoFileNameTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未选择视频"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/tsinghua_purple_dark" />

                    <!-- 文件大小信息 -->
                    <TextView
                        android:id="@+id/videoFileSizeTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/darker_gray"
                        android:layout_marginTop="8dp" />

                </LinearLayout>

                <!-- 上传进度条（初始隐藏） -->
                <LinearLayout
                    android:id="@+id/progressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/progressText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="准备上传..."
                        android:textSize="14sp"
                        android:textColor="@color/tsinghua_purple_dark"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/uploadProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="12dp"
                        android:progress="0"
                        android:max="100"
                        android:progressTint="@color/tsinghua_purple" />

                    <TextView
                        android:id="@+id/progressPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="@color/darker_gray"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <!-- 上传按钮 -->
                <Button
                    android:id="@+id/uploadButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="上传视频"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:background="@drawable/ic_button_background"
                    android:textColor="@color/white"
                    android:paddingVertical="16dp"
                    android:enabled="false" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 提示信息 -->
        <TextView
            android:id="@+id/hintTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="支持MP4、AVI、MOV等常见视频格式"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:alpha="0.8"
            app:layout_constraintTop_toBottomOf="@id/uploadCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="16dp" />

        <!-- 网络诊断按钮 -->
        <Button
            android:id="@+id/networkTestButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="网络诊断"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@drawable/ic_button_background"
            app:layout_constraintTop_toBottomOf="@id/hintTextView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp" />

        <!-- 底部占位空间 -->
        <View
            android:layout_width="0dp"
            android:layout_height="80dp"
            app:layout_constraintTop_toBottomOf="@id/networkTestButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>