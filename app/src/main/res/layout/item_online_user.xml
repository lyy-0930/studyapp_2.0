<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/tech_blue_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <!-- 用户头像/图标 -->
        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/edit_text_background"
            android:padding="8dp">

            <TextView
                android:id="@+id/userIconTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="24sp" />

            <!-- 在线状态指示器 -->
            <View
                android:id="@+id/onlineIndicator"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_online"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- 用户信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- 用户名和角色 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/usernameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="用户名"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/tech_blue_light"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- 角色标签 -->
                <TextView
                    android:id="@+id/roleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="学生"
                    android:textSize="12sp"
                    android:textColor="@color/tech_blue_accent"
                    android:background="@drawable/role_background"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- 最后登录时间 -->
            <TextView
                android:id="@+id/lastLoginTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最后登录：--"
                android:textSize="12sp"
                android:textColor="@color/tech_blue_accent"
                android:layout_marginTop="4dp" />

            <!-- 用户统计信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <!-- 学习时长 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏱️ 学习时长"
                        android:textSize="10sp"
                        android:textColor="@color/tech_blue_accent" />

                    <TextView
                        android:id="@+id/studyTimeTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0分钟"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/tech_orange_warning"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- 完成率 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ 完成率"
                        android:textSize="10sp"
                        android:textColor="@color/tech_blue_accent" />

                    <TextView
                        android:id="@+id/completionRateTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/tech_green_data"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 在线状态文字 -->
        <TextView
            android:id="@+id/onlineStatusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="在线"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/tech_green_data"
            android:background="@drawable/online_status_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>