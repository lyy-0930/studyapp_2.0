<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_gravity="top"
        android:progressTint="#00FFFF" />

    <LinearLayout
        android:id="@+id/errorView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textSize="48sp"
            android:textColor="#EF4444" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="无法连接到监控面板"
            android:textSize="16sp"
            android:textColor="#94A3B8"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/errorDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="#64748B"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请确认 Next.js 开发服务器已在电脑上运行："
            android:textSize="12sp"
            android:textColor="#64748B"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ cd monitor-dashboard &amp;&amp; npm run dev"
            android:textSize="11sp"
            android:textColor="#00FFFF"
            android:layout_marginTop="8dp"
            android:background="#0F172A"
            android:padding="8dp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="重试"
            android:layout_marginTop="20dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#0080FF" />

        <Button
            android:id="@+id/switchUrlButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="切换备用地址"
            android:layout_marginTop="8dp"
            android:textColor="#00FFFF"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>

</FrameLayout>
