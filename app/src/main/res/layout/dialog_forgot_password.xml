<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑 找回密码"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="20dp" />

        <!-- 第一步：输入用户名查询 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="第一步：输入用户名"
            android:textSize="13sp"
            android:textColor="#999999"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/forgotUsernameInput"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:hint="请输入用户名"
                android:inputType="text"
                android:maxLines="1"
                android:background="@drawable/edit_text_background"
                android:paddingHorizontal="12dp"
                android:textSize="14sp" />

            <Button
                android:id="@+id/forgotQueryBtn"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="查询"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/tsinghua_purple"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="20dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E8E8"
            android:layout_marginVertical="16dp" />

        <!-- 第二步：验证身份并设置新密码 -->
        <LinearLayout
            android:id="@+id/forgotVerifyGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="第二步：验证身份并设置新密码"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginBottom="16dp" />

            <!-- 姓名输入 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/forgotNameIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="📝"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/forgotFullNameInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="请输入注册时的真实姓名"
                    android:inputType="text"
                    android:maxLines="1"
                    android:background="@null"
                    android:layout_marginStart="16dp"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/forgotNameIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 生日输入 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/forgotBirthdayIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🎂"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/forgotBirthdayInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="请选择生日"
                    android:inputType="none"
                    android:maxLines="1"
                    android:focusable="false"
                    android:background="@null"
                    android:layout_marginStart="16dp"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/forgotBirthdayIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 密保问题展示 -->
            <TextView
                android:id="@+id/forgotQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="密保问题："
                android:textSize="14sp"
                android:textColor="@color/tsinghua_purple_dark"
                android:textStyle="bold"
                android:padding="14dp"
                android:background="#F5F0F8"
                android:layout_marginBottom="12dp" />

            <!-- 密保答案输入 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/forgotAnswerIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🔐"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/forgotAnswerInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="请输入密保答案"
                    android:inputType="text"
                    android:maxLines="1"
                    android:background="@null"
                    android:layout_marginStart="16dp"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/forgotAnswerIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E8E8"
                android:layout_marginBottom="16dp" />

            <!-- 新密码输入 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/forgotNewPwIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🔒"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/forgotNewPasswordInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="请输入新密码（至少6位）"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:background="@null"
                    android:layout_marginStart="16dp"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/forgotNewPwIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 确认新密码输入 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/forgotConfirmPwIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text="🔒"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/forgotConfirmNewPasswordInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:hint="请再次输入新密码"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:background="@null"
                    android:layout_marginStart="16dp"
                    android:textSize="14sp"
                    app:layout_constraintStart_toEndOf="@id/forgotConfirmPwIcon"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 重置按钮 -->
            <Button
                android:id="@+id/forgotResetBtn"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="重置密码"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/tsinghua_purple" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
