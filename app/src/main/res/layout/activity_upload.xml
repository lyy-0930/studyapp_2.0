<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_tsinghua_purple"
    android:padding="24dp"
    tools:context=".UploadActivity">

    <!-- 标题栏 -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 返回按钮 -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/ic_button_background_selector"
            android:contentDescription="返回"
            tools:ignore="ContentDescription" />

        <!-- 标题 -->
        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="上传文件"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center" />

        <!-- 占位空间保持对称 -->
        <View
            android:layout_width="48dp"
            android:layout_height="48dp" />

    </LinearLayout>

    <!-- 上传区域卡片 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/uploadCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="48dp"
            android:gravity="center">

            <!-- 上传图标 -->
            <TextView
                android:id="@+id/uploadIconTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📤"
                android:textSize="64sp"
                android:layout_marginBottom="24dp" />

            <!-- 上传提示 -->
            <TextView
                android:id="@+id/uploadHintTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击选择文件上传"
                android:textSize="20sp"
                android:textColor="@color/tsinghua_purple_dark"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- 上传描述 -->
            <TextView
                android:id="@+id/uploadDescriptionTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="支持图片、PDF、Word等文档格式"
                android:textSize="14sp"
                android:textColor="@color/darker_gray"
                android:gravity="center" />

            <!-- 上传按钮 -->
            <Button
                android:id="@+id/selectFileButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择文件"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/tsinghua_purple"
                android:textColor="@color/white"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:layout_marginTop="32dp" />

            <!-- 显示选中的文件名 -->
            <TextView
                android:id="@+id/selectedFileNameTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未选择文件"
                android:textSize="14sp"
                android:textColor="@color/darker_gray"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- 上传按钮 -->
            <Button
                android:id="@+id/uploadButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上传到OSS"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/tsinghua_purple"
                android:textColor="@color/white"
                android:paddingHorizontal="32dp"
                android:paddingVertical="12dp"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <!-- 上传状态 -->
            <TextView
                android:id="@+id/uploadStatusTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/darker_gray"
                android:gravity="center"
                android:layout_marginTop="16dp" />

            <!-- 显示OSS返回的URL -->
            <TextView
                android:id="@+id/urlTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="@color/tsinghua_purple"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:autoLink="web"
                android:linksClickable="true" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- 底部提示 -->
    <TextView
        android:id="@+id/hintTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择视频文件后点击上传按钮"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:alpha="0.8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
