<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="16dp"
    android:background="@drawable/gradient_tech_blue_layered"
    tools:context=".ActivityRankingActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 标题区域 -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="40dp"
            android:layout_marginHorizontal="8dp">

            <!-- 返回按钮 -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/ic_button_background_tech_selector"
                android:contentDescription="返回"
                tools:ignore="ContentDescription" />

            <!-- 标题 -->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="活跃率排行榜"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/tech_blue_light"
                android:gravity="center" />

            <!-- 筛选按钮 -->
            <TextView
                android:id="@+id/filterButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🔍"
                android:textSize="24sp"
                android:gravity="center"
                android:background="@drawable/ic_button_background_tech_selector"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 统计卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statsCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/tech_blue_primary"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- 统计标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 活跃度统计"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/tech_blue_light"
                    android:layout_marginBottom="16dp" />

                <!-- 统计指标网格 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 第一行：统计时间和总用户数 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- 统计时间 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="统计时间"
                                android:textSize="12sp"
                                android:textColor="@color/tech_blue_accent" />

                            <TextView
                                android:id="@+id/statPeriodTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最近7天"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/tech_blue_light"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <!-- 总用户数 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="统计用户数"
                                android:textSize="12sp"
                                android:textColor="@color/tech_blue_accent" />

                            <TextView
                                android:id="@+id/totalUsersTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/tech_green_data"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 第二行：平均活跃度和最高活跃度 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- 平均活跃度 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="平均活跃度"
                                android:textSize="12sp"
                                android:textColor="@color/tech_blue_accent" />

                            <TextView
                                android:id="@+id/averageActivityTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0分"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/tech_cyan_info"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <!-- 最高活跃度 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="最高活跃度"
                                android:textSize="12sp"
                                android:textColor="@color/tech_blue_accent" />

                            <TextView
                                android:id="@+id/topActivityTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0分"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/tech_orange_warning"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 第三行：活跃度分布 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="活跃度分布"
                            android:textSize="12sp"
                            android:textColor="@color/tech_blue_accent" />

                        <TextView
                            android:id="@+id/activityDistributionTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="高活跃度：0人，中等：0人，低活跃度：0人"
                            android:textSize="14sp"
                            android:textColor="@color/tech_blue_light"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 排行榜标题 -->
        <TextView
            android:id="@+id/rankingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 用户活跃度排名"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/tech_blue_light"
            app:layout_constraintTop_toBottomOf="@id/statsCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="16dp" />

        <!-- 排行榜列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rankingRecyclerView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="8dp"
            app:layout_constraintTop_toBottomOf="@id/rankingTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 底部占位空间 -->
        <View
            android:layout_width="0dp"
            android:layout_height="80dp"
            app:layout_constraintTop_toBottomOf="@id/rankingRecyclerView"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>