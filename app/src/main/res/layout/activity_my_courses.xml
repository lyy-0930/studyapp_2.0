<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/gradient_tsinghua_purple_layered"
    android:padding="8dp"
    tools:context=".MyCoursesActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题区域 -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <!-- 返回按钮 -->
            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:background="@drawable/ic_button_background_selector"
                android:contentDescription="返回"
                tools:ignore="ContentDescription" />

            <!-- 标题 -->
            <TextView
                android:id="@+id/titleTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="我的课程"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:gravity="center"
                android:paddingHorizontal="8dp" />

            <!-- 刷新按钮 -->
            <ImageButton
                android:id="@+id/refreshButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_settings"
                android:background="@drawable/ic_button_background_selector"
                android:contentDescription="刷新"
                tools:ignore="ContentDescription" />

        </LinearLayout>

        <!-- 统计卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 统计标题 -->
                <TextView
                    android:id="@+id/statsTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 我的课程统计"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/tsinghua_purple_dark"
                    android:layout_marginBottom="16dp" />

                <!-- 统计网格 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="8dp">

                    <!-- 已选课程数 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/edit_text_background">

                        <TextView
                            android:id="@+id/selectedCountValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark" />

                        <TextView
                            android:id="@+id/selectedCountLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已选课程"
                            android:textSize="13sp"
                            android:textColor="@color/darker_gray"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <!-- 间距 -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="0dp" />

                    <!-- 总学分 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/edit_text_background">

                        <TextView
                            android:id="@+id/totalCreditsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/tsinghua_purple_dark" />

                        <TextView
                            android:id="@+id/totalCreditsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总学分"
                            android:textSize="13sp"
                            android:textColor="@color/darker_gray"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 课程列表区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- 课程列表标题 -->
            <TextView
                android:id="@+id/courseListTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 已选课程列表"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="4dp" />

            <!-- 空状态提示 -->
            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone"
                android:background="@drawable/edit_text_background"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/emptyStateIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📚"
                    android:textSize="40sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/emptyStateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="暂无已选课程"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/darker_gray"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/emptyStateMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快去课程列表选择你感兴趣的课程吧！"
                    android:textSize="14sp"
                    android:textColor="@color/darker_gray"
                    android:gravity="center" />

            </LinearLayout>

            <!-- 课程列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/courseRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:clipToPadding="false"
                android:paddingVertical="8dp" />

        </LinearLayout>

        <!-- 底部提示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 提示：课程选择后可以随时退选"
            android:textSize="12sp"
            android:textColor="@color/light_gray"
            android:gravity="center"
            android:paddingVertical="12dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>