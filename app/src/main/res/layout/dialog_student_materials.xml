<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/studentDialogCourseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="课程名称"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/studentDialogCourseTeacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="授课教师："
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/studentPlayVideoBtn"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="▶ 播放视频"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/tsinghua_purple"
            android:layout_marginBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E8E8E8"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📎 课程资料"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/tsinghua_purple_dark"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/studentMaterialLoadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textSize="13sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingVertical="24dp" />

        <LinearLayout
            android:id="@+id/studentMaterialListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/studentEmptyMaterialText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无资料"
            android:textSize="13sp"
            android:textColor="#999999"
            android:gravity="center"
            android:paddingVertical="24dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
